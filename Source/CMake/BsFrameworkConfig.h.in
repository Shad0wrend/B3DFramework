#pragma once

#define B3D_VERSION_MAJOR @B3D_FRAMEWORK_VERSION_MAJOR@
#define B3D_VERSION_MINOR @B3D_FRAMEWORK_VERSION_MINOR@
#define B3D_VERSION_PATCH @B3D_FRAMEWORK_VERSION_PATCH@
#define B3D_CURRENT_RELEASE_YEAR @B3D_FRAMEWORK_CURRENT_RELEASE_YEAR@


#ifndef _STR
#define _STR(m_x) #m_x
/**
 * This macro converts the preprocessor defined macro into textual form.
 * @note Currently used internally for binary information in Win32 resource files
 */
#define _MKSTR(m_x) _STR(m_x)
#endif

#define B3D_VERSION_STRING _MKSTR(B3D_VERSION_MAJOR) "." _MKSTR(B3D_VERSION_MINOR) "." _MKSTR(B3D_VERSION_PATCH) ".0"

#define B3D_IS_ENGINE @B3D_IS_ENGINE@
